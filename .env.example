# Public site URL used to build customer pickup pass links and QR payloads.
NEXT_PUBLIC_SITE_URL=https://example.com

# Supabase (only required if you swap the mock-data layer for a real database
# — see src/lib/preorder/pickup-passes.ts and docs/database-schema.md).
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# 32-byte secret (any length is fine — it's hashed with SHA-256 to derive the
# AES-256-GCM key) used to encrypt pickup tokens for recovery/audit storage.
# Losing/rotating this secret invalidates every stored ciphertext.
PICKUP_TOKEN_ENCRYPTION_SECRET=your_32_byte_secret

# Resend (only required for sending pickup pass emails — optional dependency,
# see src/lib/email/pickup-pass.ts).
RESEND_API_KEY=your_resend_api_key
CONTACT_FROM_EMAIL=info@example.com
